<Window x:Class="LosslessChecker.Views.SpectrogramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spectrogram" Icon="pack://application:,,,/Resources/app.ico"
        Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimaryBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        ResizeMode="CanResizeWithGrip"
        MouseWheel="Window_MouseWheel"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseMove="Window_MouseMove"
        SizeChanged="Window_SizeChanged">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgTertiaryBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="6" Padding="6" Margin="0,0,0,6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Button Content="📋 Copy PNG" Click="CopyPng_Click" Margin="0,0,4,0"/>
                <Button Content="↺ Reset Zoom" Click="ResetZoom_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="65,8,65,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="42"/>
            </Grid.ColumnDefinitions>
            <Image x:Name="SpectrogramImage" Grid.Column="0" Stretch="Fill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <Canvas x:Name="OverlayCanvas" Grid.Column="0" IsHitTestVisible="False"/>
            <Canvas x:Name="LegendCanvas" Grid.Column="1" Width="42"/>
        </Grid>

        <StatusBar Grid.Row="2" Background="{DynamicResource BgPrimaryBrush}"
                   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                   Padding="4,4">
            <TextBlock x:Name="StatusText" Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
        </StatusBar>
        
        <TextBlock Grid.Row="3" Text="{Binding Title}"
                   Foreground="{DynamicResource FgMutedBrush}" FontSize="10"
                   HorizontalAlignment="Center" Margin="0,4,0,2"/>
    </Grid>
</Window>
