<Window x:Class="LosslessChecker.Views.SpectrogramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spectrogram" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimaryBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
        ResizeMode="CanResizeWithGrip"
        MouseWheel="Window_MouseWheel"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseMove="Window_MouseMove"
        SizeChanged="Window_SizeChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}">
            <Button Content="📋 Copy PNG" Click="CopyPng_Click"
                    Foreground="{DynamicResource FgPrimaryBrush}" BorderThickness="0" Margin="4" Cursor="Hand"/>
            <Button Content="↺ Reset" Click="ResetZoom_Click"
                    Foreground="{DynamicResource FgPrimaryBrush}" BorderThickness="0" Margin="4" Cursor="Hand"/>
        </ToolBar>

        <Grid Grid.Row="1" Margin="65,10,50,30">
            <Image x:Name="SpectrogramImage" Stretch="Fill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False"/>
        </Grid>

        <StatusBar Grid.Row="2" Background="{DynamicResource BgPrimaryBrush}">
            <TextBlock x:Name="StatusText" Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
        </StatusBar>
        
        <TextBlock Grid.Row="3" Text="{Binding Title}"
                   Foreground="{DynamicResource FgMutedBrush}" FontSize="11"
                   HorizontalAlignment="Center" Margin="0,2,0,6"/>
    </Grid>
</Window>
