<Window x:Class="LosslessChecker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LosslessChecker.Converters"
        xmlns:models="clr-namespace:LosslessChecker.Models"
        xmlns:viewmodels="clr-namespace:LosslessChecker.ViewModels"
        Title="LosslessChecker — Анализ аутентичности аудио"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimaryBrush}"
        Foreground="{DynamicResource FgPrimaryBrush}"
        FontFamily="Segoe UI"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">

    <Window.Resources>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        <converters:AuthenticityToColorConverter x:Key="AuthToColor"/>
        <converters:DecisionToColorConverter x:Key="DecToColor"/>
        <converters:ScoreToIconConverter x:Key="IconConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBool"/>
        <converters:DurationFormatConverter x:Key="DurationFormat"/>
        <converters:BytesToImageConverter x:Key="BytesToImage"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisInverse" Invert="True"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="MetricHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#0f0f1a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource BgPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type models:ArtistGroup}"
                                  ItemsSource="{Binding Albums}">
            <TextBlock Text="{Binding ArtistName}" FontWeight="SemiBold"
                       FontSize="12.5" Margin="0,1"/>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type models:AlbumGroup}"
                                  ItemsSource="{Binding Tracks}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding AlbumName}" FontSize="12" Margin="8,0,4,0" VerticalAlignment="Center"/>
                <Border CornerRadius="3" Padding="4,1" Margin="4,0,0,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AlbumVerdict}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AlbumVerdict}" Value="LOSSLESS">
                                    <Setter Property="Background" Value="{DynamicResource LosslessGreenBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AlbumVerdict}" Value="NOT SURE">
                                    <Setter Property="Background" Value="{DynamicResource SuspiciousAmberBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AlbumVerdict}" Value="REPLACE">
                                    <Setter Property="Background" Value="{DynamicResource FakeRedBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding AlbumVerdict}" FontSize="9" Foreground="#0f0f1a" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:AudioFileViewModel}">
            <TextBlock Text="{Binding FileName}" FontSize="11"
                       Foreground="{DynamicResource FgSecondaryBrush}" Margin="16,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Border x:Name="MainContent" Visibility="{Binding ShowWelcome, Converter={StaticResource InvertBool}}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📁 Папка" Command="{Binding SelectFolderCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100" Height="34" Margin="0,0,6,0"/>
                <Button Grid.Column="1" Content="📂 Файлы" Command="{Binding SelectFilesCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="90" Height="34" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Content="⏹ Стоп" Command="{Binding StopCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Width="80" Height="34" Margin="0,0,6,0"/>
                <Button Grid.Column="3" Content="➕ Добавить" Command="{Binding AddFilesCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="100" Height="34" Margin="0,0,6,0"/>
                <Button Grid.Column="4" Content="📊 Экспорт" Command="{Binding ExportCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="90" Height="34" Margin="0,0,6,0"/>
                <Grid Grid.Column="5" Margin="20,0,0,0">
                    <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100"
                                 Height="8" VerticalAlignment="Center"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="{DynamicResource BgTertiaryBrush}"/>
                    <TextBlock Text="{Binding ProgressText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="10" Foreground="{DynamicResource FgMutedBrush}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Main three-panel layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- TreeView -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10,10,0,0"
                            Padding="10,6">
                        <TextBlock Text="🔍 Коллекция" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgMutedBrush}"/>
                    </Border>
                    <TreeView Grid.Row="1" x:Name="GroupTreeView"
                              ItemsSource="{Binding ArtistGroups}"
                              Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                              BorderThickness="0" Padding="4,6"
                              SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4a9eff"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1e1e1e"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#4a9eff"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1e1e1e"/>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- DataGrid -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Width="180" Margin="0,0,8,0"
                             Background="{DynamicResource BgSecondaryBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" FontSize="11"
                             ToolTip="Поиск по названию, артисту, альбому"/>
                    <ToggleButton Content="LOSSLESS" IsChecked="{Binding ShowKeep}" Width="70"
                                   Background="#1a3022" Foreground="{DynamicResource LosslessGreenBrush}" Margin="2,0" FontSize="10"/>
                    <ToggleButton Content="NOT SURE" IsChecked="{Binding ShowInvestigate}" Width="70"
                                   Background="#2e2a1a" Foreground="{DynamicResource SuspiciousAmberBrush}" Margin="2,0" FontSize="10"/>
                    <ToggleButton Content="REPLACE" IsChecked="{Binding ShowReplace}" Width="65"
                                   Background="#301a1a" Foreground="{DynamicResource FakeRedBrush}" Margin="2,0" FontSize="10"/>
                    <ToggleButton Content="MP3" IsChecked="{Binding ShowMp3}" Width="45"
                                   Background="{DynamicResource BgSecondaryBrush}" Foreground="#f9e2af" Margin="2,0" FontSize="10"/>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid x:Name="FilesGrid"
                      ItemsSource="{Binding FilesView}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                       Background="{DynamicResource BgPrimaryBrush}" Foreground="{DynamicResource FgPrimaryBrush}" BorderThickness="0"
                       RowBackground="{DynamicResource BgPrimaryBrush}" AlternatingRowBackground="{DynamicResource GridAltRowBrush}"
                       GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BgSecondaryBrush}"
                      HeadersVisibility="Column" SelectionMode="Single"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      ScrollViewer.CanContentScroll="True"
                      CanUserSortColumns="True"
                      Sorting="DataGrid_Sorting"
                      SelectionChanged="DataGrid_SelectionChanged">
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#818cf8"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#0f0f1a"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#334155"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#e2e8f0"/>
                </DataGrid.Resources>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="📂 Открыть папку с файлом"
                                  Command="{Binding OpenFolderCommand}"/>
                        <MenuItem Header="📋 Копировать метрики"
                                  Command="{Binding SelectedFile.CopyMetricsCommand}"/>
                        <MenuItem Header="🔬 Показать спектрограмму"
                                  Command="{Binding OpenSpectrogramCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="35">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AnalysisStatus, Converter={StaticResource IconConverter}}"
                                           HorizontalAlignment="Center" FontSize="14"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Название" Binding="{Binding FileName}" Width="180"
                                       SortMemberPath="FileName" SortDirection="Ascending">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Длит." Width="55"
                                           SortMemberPath="DurationSeconds">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DurationSeconds, Converter={StaticResource DurationFormat}}"
                                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource FgMutedBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Формат" Binding="{Binding Format}" Width="60"
                                       SortMemberPath="Format"/>
                    <DataGridTemplateColumn Header="Битрейт" Width="70"
                                            SortMemberPath="ActualBitrate">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding BitrateDisplay}"
                                           FontSize="10" FontFamily="Consolas"
                                           Foreground="{Binding BitrateColor}"
                                           HorizontalAlignment="Center"
                                           ToolTip="Заявленный → Реальный (kbps)"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Cutoff" Binding="{Binding CutoffFrequency, StringFormat={}{0:F0} Гц}" Width="60"
                                       SortMemberPath="CutoffFrequency"/>
                    <DataGridTextColumn Header="DR" Binding="{Binding DynamicRange, StringFormat={}{0:F0}}" Width="40"
                                       SortMemberPath="DynamicRange"/>
                    <DataGridTextColumn Header="Подлинность" Binding="{Binding Authenticity}" Width="100"
                                       SortMemberPath="Authenticity">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Authenticity, Converter={StaticResource AuthToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Кач-во" Binding="{Binding QualityScorePercent, StringFormat={}{0:F0}%}" Width="55"
                                       SortMemberPath="QualityScorePercent">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding QualityScorePercent, Converter={StaticResource ScoreToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Решение" Binding="{Binding VerdictLabel}" Width="90"
                                        SortMemberPath="VerdictLabel">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding VerdictLabel, Converter={StaticResource DecToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
                </DataGrid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="3" Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Detail Panel -->
            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsSpectrumVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="8">

                    <Button Content="📋 Копировать таблицу"
                            Command="{Binding SelectedFile.CopyMetricsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="28" Margin="0,0,0,8"/>

                    <!-- Album Summary -->
                    <Border Style="{StaticResource CardStyle}" Padding="12,10" Margin="0,0,0,8"
                            Visibility="{Binding SelectedGroup, Converter={StaticResource NullToVis}}"
                            Effect="{StaticResource ShadowE2}">
                        <StackPanel>
                            <TextBlock FontSize="14" FontWeight="Bold" Foreground="{DynamicResource FgPrimaryBrush}"
                                       Text="{Binding SelectedGroup.AlbumName}" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                            <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Left" Margin="0,0,0,8"
                                    Background="{Binding SelectedGroup.AlbumVerdict, Converter={StaticResource DecToColor}}">
                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BgPrimaryBrush}"
                                           Text="{Binding SelectedGroup.AlbumVerdict, StringFormat=ALBUM: {0}}"/>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" FontSize="11" Foreground="{DynamicResource FgMutedBrush}"
                                           Text="{Binding SelectedGroup.AverageQualityScore, StringFormat=Ср. качество: {0:F0}%}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" FontSize="11" Foreground="{DynamicResource FgMutedBrush}"
                                           Text="{Binding SelectedGroup.AverageDynamicRange, StringFormat=Ср. DR: {0:F0}}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" FontSize="11" Foreground="{DynamicResource LosslessGreenBrush}"
                                           Text="{Binding SelectedGroup.KeepCount, StringFormat=KEEP: {0}}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" FontSize="11" Foreground="{DynamicResource SuspiciousAmberBrush}"
                                           Text="{Binding SelectedGroup.InvestigateCount, StringFormat=INVESTIGATE: {0}}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" FontSize="11" Foreground="{DynamicResource FakeRedBrush}"
                                           Text="{Binding SelectedGroup.ReplaceCount, StringFormat=REPLACE: {0}}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" Foreground="{DynamicResource FgMutedBrush}"
                                           Text="{Binding SelectedGroup.Tracks.Count, StringFormat=Треков: {0}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Cover art -->
                    <Border Style="{StaticResource CardStyle}" Height="200" Margin="0,0,0,8"
                            Visibility="{Binding SelectedFile, Converter={StaticResource NullToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Image Grid.Row="1" Stretch="Uniform" Margin="8"
                                   Source="{Binding SelectedFile.CoverData, Converter={StaticResource BytesToImage}}"
                                   Visibility="{Binding SelectedFile.CoverData, Converter={StaticResource NullToVis}}"/>

                            <Border Grid.Row="1"
                                    Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4" Margin="8"
                                    Visibility="{Binding SelectedFile.CoverData, Converter={StaticResource NullToVisInverse}}">
                                <TextBlock Text="🎵" FontSize="48"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource FgSubtleBrush}"/>
                            </Border>

                            <StackPanel Grid.Row="2" Margin="8,4,8,8">
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FgPrimaryBrush}" TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedFile.Artist, FallbackValue=''}"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource FgSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedFile.Album, FallbackValue=''}"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource FgMutedBrush}"
                                           Text="{Binding SelectedGroup.Genre, FallbackValue=''}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Spectrogram (clickable) -->
                    <Border Style="{StaticResource CardStyle}" Height="180" Margin="0,0,0,10"
                            Cursor="Hand" MouseLeftButtonDown="Spectrogram_Click">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding SpectrumTitle}"
                                       Foreground="{DynamicResource FgMutedBrush}" FontSize="10"
                                       TextTrimming="CharacterEllipsis" Margin="6,4"/>
                            <Image Grid.Row="1" Stretch="Uniform" Margin="2"
                                   Source="{Binding SelectedFile.SpectrogramBitmap}"/>
                            <TextBlock Grid.Row="1" Text="🔍 Click to enlarge"
                                       Foreground="{DynamicResource FgSubtleBrush}" FontSize="9"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Margin="0,0,6,4"/>
                        </Grid>
                    </Border>

                    <!-- Cutoff info bar -->
                    <Border Background="{DynamicResource GridAltRowBrush}" CornerRadius="6" Padding="8,4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="{DynamicResource FakeRedBrush}" FontSize="11">
                                <Run Text="Срез: "/>
                                <Run Text="{Binding SelectedCutoffFrequency, StringFormat={}{0:F0}}" FontWeight="Bold"/>
                                <Run Text=" Гц"/>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource FgSubtleBrush}" FontSize="11" Margin="12,0,0,0">
                                <Run Text="Nyquist: "/>
                                <Run Text="{Binding SelectedNyquist, StringFormat={}{0:F0}}" FontWeight="Bold"/>
                                <Run Text=" Гц"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Verdict bar -->
                    <Border CornerRadius="8" Padding="10,8" Margin="0,0,0,8"
                            Background="{Binding SelectedFile.VerdictLabel, Converter={StaticResource DecToColor}}"
                            Effect="{StaticResource ShadowE1}">
                        <StackPanel>
                            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,4"
                                       Foreground="{Binding SelectedFile.VerdictLabel, Converter={StaticResource DecToColor}}">
                                <Run Text="{Binding SelectedFile.VerdictDisplayText, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{DynamicResource FgMutedBrush}">
                                <Run Text="Подлинность: "/>
                                <Run Text="{Binding SelectedFile.Authenticity}" FontWeight="Bold"
                                     Foreground="{Binding SelectedFile.Authenticity, Converter={StaticResource AuthToColor}}"/>
                                <Run Text=" | Качество: "/>
                                <Run Text="{Binding SelectedFile.QualityScorePercent, StringFormat={}{0:F0}%}" FontWeight="Bold"
                                      Foreground="{Binding SelectedFile.QualityScorePercent, Converter={StaticResource ScoreToColor}}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Metrics table -->
                    <ItemsControl ItemsSource="{Binding SelectedFile.MetricItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding Name}"
                                               Visibility="{Binding IsHeader, Converter={StaticResource BoolToVis}}"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="Bold"
                                               Margin="0,10,0,4" TextDecorations="Underline"/>

                                    <Border Visibility="{Binding IsHeader, Converter={StaticResource InvertBool}}"
                                            Background="{DynamicResource BgSecondaryBrush}" CornerRadius="6" Padding="8,5" Margin="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontSize="10.5"
                                                           Foreground="{DynamicResource FgSecondaryBrush}" ToolTip="{Binding Description}"/>
                                                <TextBlock Text="{Binding Typical}" FontSize="9"
                                                           Foreground="{DynamicResource FgSubtleBrush}" FontStyle="Italic"
                                                           Margin="0,2,0,0" ToolTip="{Binding Description}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Value}" FontSize="10.5"
                                                           FontFamily="Consolas" Foreground="{DynamicResource FgPrimaryBrush}"
                                                           FontWeight="SemiBold" Margin="0,0,10,0"/>
                                                <Border CornerRadius="3" Padding="6,2"
                                                        Background="{Binding StatusColor}">
                                                    <TextBlock Text="{Binding Status}" FontSize="9.5"
                                                               Foreground="{DynamicResource BgPrimaryBrush}" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Summary bar -->
        <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}" Padding="12,8" Margin="0,6,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding SummaryText}" Foreground="{DynamicResource FgMutedBrush}" FontSize="13"
                           Visibility="{Binding CurrentlyProcessing, Converter={StaticResource NullToVisInverse}}"/>
                <TextBlock Text="{Binding CurrentlyProcessing}" Foreground="{DynamicResource AccentBrush}" FontSize="13"
                           FontWeight="SemiBold"
                           Visibility="{Binding CurrentlyProcessing, Converter={StaticResource NullToVis}}"/>
            </StackPanel>
        </Border>
        </Grid>
        </Border>

        <Border x:Name="WelcomeContent" Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource BgPrimaryBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎵" FontSize="64" HorizontalAlignment="Center" Foreground="{DynamicResource FgSubtleBrush}"/>
                <TextBlock Text="Перетащите папку с аудио сюда" FontSize="18" Foreground="{DynamicResource FgMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,12"/>
                <Button Content="📁 Выбрать папку" Command="{Binding SelectFolderCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="160" Height="38" Margin="0,16"/>
                <TextBlock Text="или перетащите файлы для быстрого анализа" FontSize="12" Foreground="{DynamicResource FgSubtleBrush}"
