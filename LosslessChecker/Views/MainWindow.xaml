<Window x:Class="LosslessChecker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LosslessChecker.Converters"
        xmlns:models="clr-namespace:LosslessChecker.Models"
        xmlns:viewmodels="clr-namespace:LosslessChecker.ViewModels"
        Title="LosslessChecker — Анализ аутентичности аудио"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimaryBrush}"
        Foreground="{DynamicResource FgPrimaryBrush}"
        FontFamily="Segoe UI"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">

    <Window.Resources>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        <converters:AuthenticityToColorConverter x:Key="AuthToColor"/>
        <converters:DecisionToColorConverter x:Key="DecToColor"/>
        <converters:ScoreToIconConverter x:Key="IconConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBool"/>
        <converters:DurationFormatConverter x:Key="DurationFormat"/>
        <converters:BytesToImageConverter x:Key="BytesToImage"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisInverse" Invert="True"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Metric header -->
        <Style x:Key="MetricHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>

        <!-- Metric name -->
        <Style x:Key="MetricNameStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource FgSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Metric value -->
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <!-- Metric status badge -->
        <Style x:Key="MetricStatusStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- DataGrid column header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- DataGrid cell -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- TreeView item style -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource BgPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Hierarchical templates for TreeView -->
        <HierarchicalDataTemplate DataType="{x:Type models:ArtistGroup}"
                                  ItemsSource="{Binding Albums}">
            <TextBlock Text="{Binding ArtistName}" FontWeight="SemiBold"
                       FontSize="12.5" Margin="0,1"/>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type models:AlbumGroup}"
                                  ItemsSource="{Binding Tracks}">
            <TextBlock Text="{Binding AlbumName}" FontSize="12" Margin="8,0,0,0"/>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:AudioFileViewModel}">
            <TextBlock Text="{Binding FileName}" FontSize="11"
                       Foreground="{DynamicResource FgSecondaryBrush}" Margin="16,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </DataTemplate>

        <!-- Cover placeholder brush -->
        <SolidColorBrush x:Key="PlaceholderBrush" Color="#313244"/>
    </Window.Resources>

    <Grid>
        <Border x:Name="MainContent" Visibility="{Binding ShowWelcome, Converter={StaticResource InvertBool}}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" CornerRadius="8" Background="{DynamicResource BgSecondaryBrush}" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📁 Выбрать папку" Command="{Binding SelectFolderCommand}"
                        Width="140" Height="34" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource BgPrimaryBrush}"
                        BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <Button Grid.Column="1" Content="⏹ Стоп" Command="{Binding StopCommand}"
                        Width="80" Height="34" Background="#f38ba8" Foreground="{DynamicResource BgPrimaryBrush}"
                        BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Margin="8,0,0,0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <Button Grid.Column="2" Content="📊 Экспорт" Command="{Binding ExportCommand}"
                        Width="90" Height="34" Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                        BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Margin="8,0,0,0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <ProgressBar Grid.Column="3" Value="{Binding Progress}" Minimum="0" Maximum="100"
                             Height="8" Margin="20,0,0,0" Foreground="#a6e3a1" Background="{DynamicResource BorderBrush}"/>
            </Grid>
        </Border>

        <!-- Main three-panel layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- TreeView: Artist → Album grouping -->
            <Border Grid.Column="0" CornerRadius="8" Background="{DynamicResource BgTertiaryBrush}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8,8,0,0"
                            Padding="10,6">
                        <TextBlock Text="🔍 Коллекция" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgMutedBrush}"/>
                    </Border>
                    <TreeView Grid.Row="1" x:Name="GroupTreeView"
                              ItemsSource="{Binding ArtistGroups}"
                              Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                              BorderThickness="0" Padding="4,6"
                              SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                             Color="{DynamicResource AccentBrush}"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                             Color="{DynamicResource BgPrimaryBrush}"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                             Color="{DynamicResource AccentBrush}"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                             Color="{DynamicResource BgPrimaryBrush}"/>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- DataGrid: track list -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Width="180" Margin="0,0,8,0"
                             Background="{DynamicResource BgSecondaryBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" FontSize="11"
                             ToolTip="Поиск по названию, артисту, альбому"/>
                    <ToggleButton Content="KEEP" IsChecked="{Binding ShowKeep}" Width="50"
                                   Background="#1a3022" Foreground="{DynamicResource LosslessGreenBrush}" Margin="2,0" FontSize="10"/>
                    <ToggleButton Content="INV" IsChecked="{Binding ShowInvestigate}" Width="40"
                                   Background="#2e2a1a" Foreground="{DynamicResource SuspiciousAmberBrush}" Margin="2,0" FontSize="10"/>
                    <ToggleButton Content="REPL" IsChecked="{Binding ShowReplace}" Width="45"
                                   Background="#301a1a" Foreground="{DynamicResource FakeRedBrush}" Margin="2,0" FontSize="10"/>
                    <ToggleButton Content="MP3" IsChecked="{Binding ShowMp3}" Width="40"
                                   Background="{DynamicResource BgSecondaryBrush}" Foreground="#f9e2af" Margin="2,0" FontSize="10"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="FilesGrid"
                      ItemsSource="{Binding FilteredFiles}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                       Background="{DynamicResource BgPrimaryBrush}" Foreground="{DynamicResource FgPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}"
                       RowBackground="{DynamicResource BgPrimaryBrush}" AlternatingRowBackground="{DynamicResource GridAltRowBrush}"
                       GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BgSecondaryBrush}"
                      HeadersVisibility="Column" SelectionMode="Single"
                      EnableRowVirtualization="True" ScrollViewer.CanContentScroll="True"
                      CanUserSortColumns="True"
                      Sorting="DataGrid_Sorting"
                      SelectionChanged="DataGrid_SelectionChanged">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="📂 Открыть папку с файлом" Click="OpenFolder_Click"/>
                        <MenuItem Header="📋 Копировать метрики" Click="CopyMetrics_Click"/>
                        <MenuItem Header="🔬 Показать спектрограмму" Click="SpectrogramContext_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="35">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AnalysisStatus, Converter={StaticResource IconConverter}}"
                                           HorizontalAlignment="Center" FontSize="14"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Название" Binding="{Binding FileName}" Width="180"
                                       SortMemberPath="FileName" SortDirection="Ascending">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Длит." Width="55"
                                           SortMemberPath="DurationSeconds">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DurationSeconds, Converter={StaticResource DurationFormat}}"
                                           HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource FgMutedBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Формат" Binding="{Binding Format}" Width="60"
                                       SortMemberPath="Format"/>
                    <DataGridTextColumn Header="Cutoff" Binding="{Binding CutoffFrequency, StringFormat={}{0:F0} Гц}" Width="60"
                                       SortMemberPath="CutoffFrequency"/>
                    <DataGridTextColumn Header="DR" Binding="{Binding DynamicRange, StringFormat={}{0:F0}}" Width="40"
                                       SortMemberPath="DynamicRange"/>
                    <DataGridTextColumn Header="Подлинность" Binding="{Binding Authenticity}" Width="100"
                                       SortMemberPath="Authenticity">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Authenticity, Converter={StaticResource AuthToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Кач-во" Binding="{Binding QualityScorePercent, StringFormat={}{0:F0}%}" Width="55"
                                       SortMemberPath="QualityScorePercent">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding QualityScorePercent, Converter={StaticResource ScoreToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Решение" Binding="{Binding Decision}" Width="90"
                                       SortMemberPath="Decision">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Decision, Converter={StaticResource DecToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <GridSplitter Grid.Column="3" Width="3" Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Detail Panel -->
            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsSpectrumVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="8">

                    <!-- Copy button -->
                    <Button Content="📋 Копировать таблицу"
                            Command="{Binding SelectedFile.CopyMetricsCommand}"
                            Height="28" Margin="0,0,0,8"
                            Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource FgPrimaryBrush}"
                            BorderThickness="0" FontSize="11"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                    </Button>

                    <!-- Cover art + Artist/Album/Genre -->
                    <Border Background="#11111b" CornerRadius="6" Padding="0" Margin="0,0,0,8"
                            Height="200">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Cover image -->
                            <Image Grid.Row="1" x:Name="CoverImage"
                                   Stretch="Uniform" Margin="8"
                                   Source="{Binding SelectedGroup.CoverData, Converter={StaticResource BytesToImage}}"
                                   Visibility="{Binding SelectedGroup.CoverData, Converter={StaticResource NullToVis}}"/>

                            <!-- Placeholder when no cover -->
                            <Border x:Name="CoverPlaceholder" Grid.Row="1"
                                    Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4" Margin="8"
                                    Visibility="{Binding SelectedGroup.CoverData, Converter={StaticResource NullToVisInverse}}">
                                <TextBlock Text="🎵" FontSize="48"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource FgSubtleBrush}"/>
                            </Border>

                            <!-- Artist / Album / Genre info -->
                            <StackPanel Grid.Row="2" Margin="8,4,8,8">
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FgPrimaryBrush}" TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedFile.Artist, FallbackValue=''}"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource FgSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedFile.Album, FallbackValue=''}"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource FgMutedBrush}"
                                           Text="{Binding SelectedGroup.Genre, FallbackValue=''}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Spectrogram (clickable) -->
                    <Border Background="#11111b" CornerRadius="6" Height="180" Margin="0,0,0,10"
                            Cursor="Hand" MouseLeftButtonDown="Spectrogram_Click">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding SpectrumTitle}"
                                       Foreground="{DynamicResource FgMutedBrush}" FontSize="10"
                                       TextTrimming="CharacterEllipsis" Margin="6,4"/>
                            <Image Grid.Row="1" x:Name="SpectrogramImage"
                                   Stretch="Uniform" Margin="2"/>
                            <!-- Click hint -->
                            <TextBlock Grid.Row="1" Text="🔍 Click to enlarge"
                                       Foreground="{DynamicResource FgSubtleBrush}" FontSize="9"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Margin="0,0,6,4"/>
                        </Grid>
                    </Border>

                    <!-- Cutoff info bar -->
                    <Border Background="{DynamicResource GridAltRowBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="#f38ba8" FontSize="11">
                                <Run Text="Срез: "/>
                                <Run Text="{Binding SelectedCutoffFrequency, StringFormat={}{0:F0}}" FontWeight="Bold"/>
                                <Run Text=" Гц"/>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource FgSubtleBrush}" FontSize="11" Margin="12,0,0,0">
                                <Run Text="Nyquist: "/>
                                <Run Text="{Binding SelectedNyquist, StringFormat={}{0:F0}}" FontWeight="Bold"/>
                                <Run Text=" Гц"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Verdict bar -->
                    <Border CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="KEEP">
                                        <Setter Property="Background" Value="#1a3022"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="KEEP (poor master)">
                                        <Setter Property="Background" Value="#2e2a1a"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="INVESTIGATE">
                                        <Setter Property="Background" Value="#2e2a1a"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="REPLACE">
                                        <Setter Property="Background" Value="#301a1a"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="KEEP">
                                                <Setter Property="Text" Value="✅ ОСТАВИТЬ"/>
                                                <Setter Property="Foreground" Value="{DynamicResource LosslessGreenBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="KEEP (poor master)">
                                                <Setter Property="Text" Value="⚠ ОСТАВИТЬ (плохой мастеринг)"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuspiciousAmberBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="INVESTIGATE">
                                                <Setter Property="Text" Value="🔍 ПРОВЕРИТЬ"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuspiciousAmberBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="REPLACE">
                                                <Setter Property="Text" Value="❌ ЗАМЕНИТЬ"/>
                                                <Setter Property="Foreground" Value="{DynamicResource FakeRedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{DynamicResource FgMutedBrush}">
                                <Run Text="Подлинность: "/>
                                <Run Text="{Binding SelectedFile.Authenticity}" FontWeight="Bold"
                                     Foreground="{Binding SelectedFile.Authenticity, Converter={StaticResource AuthToColor}}"/>
                                <Run Text=" | Качество: "/>
                                <Run Text="{Binding SelectedFile.QualityScorePercent, StringFormat={}{0:F0}%}" FontWeight="Bold"
                                      Foreground="{Binding SelectedFile.QualityScorePercent, Converter={StaticResource ScoreToColor}}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Metrics table -->
                    <ItemsControl ItemsSource="{Binding SelectedFile.MetricItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- Header row: visible when IsHeader=true -->
                                    <TextBlock Text="{Binding Name}"
                                               Visibility="{Binding IsHeader, Converter={StaticResource BoolToVis}}"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="Bold"
                                               Margin="0,10,0,4" TextDecorations="Underline"/>

                                    <!-- Metric row: visible when IsHeader=false -->
                                    <Border Visibility="{Binding IsHeader, Converter={StaticResource InvertBool}}"
                                            Background="{DynamicResource BgPrimaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontSize="10.5"
                                                           Foreground="{DynamicResource FgSecondaryBrush}" ToolTip="{Binding Description}"/>
                                                <TextBlock Text="{Binding Typical}" FontSize="9"
                                                           Foreground="{DynamicResource FgSubtleBrush}" FontStyle="Italic"
                                                           Margin="0,2,0,0" ToolTip="{Binding Description}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Value}" FontSize="10.5"
                                                           FontFamily="Consolas" Foreground="{DynamicResource FgPrimaryBrush}"
                                                           FontWeight="SemiBold" Margin="0,0,10,0"/>
                                                <Border CornerRadius="3" Padding="6,2"
                                                        Background="{Binding StatusColor}">
                                                    <TextBlock Text="{Binding Status}" FontSize="9.5"
                                                               Foreground="{DynamicResource BgPrimaryBrush}" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Summary bar -->
        <Border Grid.Row="2" CornerRadius="8" Background="{DynamicResource BgSecondaryBrush}" Padding="12,8" Margin="0,6,0,0">
            <TextBlock Text="{Binding SummaryText}" Foreground="{DynamicResource FgMutedBrush}" FontSize="13"/>
        </Border>
        </Grid>
        </Border>

        <Border x:Name="WelcomeContent" Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource BgPrimaryBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎵" FontSize="64" HorizontalAlignment="Center" Foreground="#585b70"/>
                <TextBlock Text="Перетащите папку с аудио сюда" FontSize="18" Foreground="#a6adc8"
                           HorizontalAlignment="Center" Margin="0,12"/>
                <TextBlock Text="или нажмите Выбрать папку чтобы начать анализ" FontSize="12" Foreground="#585b70"
                           HorizontalAlignment="Center"/>
                <Border BorderBrush="#45475a" BorderThickness="2" CornerRadius="12"
                        Margin="40,20" Padding="20">
                    <TextBlock Text=".mp3  .flac  .wav  .m4a  .alac"
                               Foreground="#585b70" FontSize="11" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
