<Window x:Class="LosslessChecker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LosslessChecker.Converters"
        Title="LosslessChecker — Анализ аутентичности аудио"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e"
        Foreground="#cdd6f4"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        <converters:AuthenticityToColorConverter x:Key="AuthToColor"/>
        <converters:DecisionToColorConverter x:Key="DecToColor"/>
        <converters:ScoreToIconConverter x:Key="IconConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBool"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Style for metric header rows -->
        <Style x:Key="MetricHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#a6adc8"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>

        <!-- Style for metric name -->
        <Style x:Key="MetricNameStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#bac2de"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Style for metric value -->
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <!-- Style for metric status badge -->
        <Style x:Key="MetricStatusStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- DataGrid cell styles -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#a6adc8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" CornerRadius="8" Background="#313244" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📁 Выбрать папку" Command="{Binding SelectFolderCommand}"
                        Width="140" Height="34" Background="#89b4fa" Foreground="#1e1e2e"
                        BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <Button Grid.Column="1" Content="⏹ Стоп" Command="{Binding StopCommand}"
                        Width="80" Height="34" Background="#f38ba8" Foreground="#1e1e2e"
                        BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Margin="8,0,0,0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <ProgressBar Grid.Column="2" Value="{Binding Progress}" Minimum="0" Maximum="100"
                             Height="8" Margin="20,0,0,0" Foreground="#a6e3a1" Background="#45475a"/>
            </Grid>
        </Border>

        <!-- Master-Detail split -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="460"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid (left) -->
            <DataGrid Grid.Column="0" x:Name="FilesGrid"
                      ItemsSource="{Binding Files}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                      Background="#1e1e2e" Foreground="#cdd6f4" BorderBrush="#45475a"
                      RowBackground="#1e1e2e" AlternatingRowBackground="#242438"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#313244"
                      HeadersVisibility="Column" SelectionMode="Single"
                      EnableRowVirtualization="True" ScrollViewer.CanContentScroll="True"
                      SelectionChanged="DataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="35">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AnalysisStatus, Converter={StaticResource IconConverter}}"
                                           HorizontalAlignment="Center" FontSize="14"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Название" Binding="{Binding FileName}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Формат" Binding="{Binding Format}" Width="100"/>
                    <DataGridTextColumn Header="Срез" Binding="{Binding CutoffFrequency, StringFormat={}{0:F0} Гц}" Width="70"/>
                    <DataGridTextColumn Header="DR" Binding="{Binding DynamicRange, StringFormat={}{0:F1}}" Width="45"/>
                    <DataGridTextColumn Header="TPeak" Binding="{Binding TruePeakDb, StringFormat={}{0:F1}}" Width="50"/>
                    <DataGridTextColumn Header="Клип" Binding="{Binding ClippingPercent, StringFormat={}{0:F2}}" Width="50"/>
                    <DataGridTextColumn Header="Аутентичность" Binding="{Binding Authenticity}" Width="105">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Authenticity, Converter={StaticResource AuthToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Кач-во" Binding="{Binding QualityScore, StringFormat={}{0}/10}" Width="55">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding QualityScore, Converter={StaticResource ScoreToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Решение" Binding="{Binding Decision}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Decision, Converter={StaticResource DecToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="4" Background="#45475a"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Detail Panel (right) -->
            <Border Grid.Column="2" CornerRadius="8" Background="#181825" Padding="0"
                    Visibility="{Binding IsSpectrumVisible, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <!-- Copy button -->
                        <Button Content="📋 Копировать таблицу"
                                Command="{Binding SelectedFile.CopyMetricsCommand}"
                                Height="28" Margin="0,0,0,8"
                                Background="#45475a" Foreground="#cdd6f4"
                                BorderThickness="0" FontSize="11"
                                Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                            </Button.Resources>
                        </Button>

                        <!-- Spectrogram -->
                        <Border Background="#11111b" CornerRadius="6" Height="160" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding SpectrumTitle}"
                                           Foreground="#a6adc8" FontSize="10"
                                           TextTrimming="CharacterEllipsis" Margin="6,4"/>
                                <Image Grid.Row="1" x:Name="SpectrogramImage"
                                       Stretch="Uniform" Margin="2"/>
                            </Grid>
                        </Border>

                        <!-- Cutoff info bar -->
                        <Border Background="#242438" CornerRadius="4" Padding="8,4" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Foreground="#f38ba8" FontSize="11">
                                    <Run Text="Срез: "/>
                                    <Run Text="{Binding SelectedCutoffFrequency, StringFormat={}{0:F0}}" FontWeight="Bold"/>
                                    <Run Text=" Гц"/>
                                </TextBlock>
                                <TextBlock Foreground="#585b70" FontSize="11" Margin="12,0,0,0">
                                    <Run Text="Nyquist: "/>
                                    <Run Text="{Binding SelectedNyquist, StringFormat={}{0:F0}}" FontWeight="Bold"/>
                                    <Run Text=" Гц"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Verdict bar -->
                        <Border CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="KEEP">
                                            <Setter Property="Background" Value="#1a3022"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="KEEP (poor master)">
                                            <Setter Property="Background" Value="#2e2a1a"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="INVESTIGATE">
                                            <Setter Property="Background" Value="#2e2a1a"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="REPLACE">
                                            <Setter Property="Background" Value="#301a1a"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="KEEP">
                                                    <Setter Property="Text" Value="✅ ОСТАВИТЬ"/>
                                                    <Setter Property="Foreground" Value="#2EA043"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="KEEP (poor master)">
                                                    <Setter Property="Text" Value="⚠ ОСТАВИТЬ (плохой мастеринг)"/>
                                                    <Setter Property="Foreground" Value="#D29922"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="INVESTIGATE">
                                                    <Setter Property="Text" Value="🔍 ПРОВЕРИТЬ"/>
                                                    <Setter Property="Foreground" Value="#D29922"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedFile.Decision}" Value="REPLACE">
                                                    <Setter Property="Text" Value="❌ ЗАМЕНИТЬ"/>
                                                    <Setter Property="Foreground" Value="#CF222E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="#a6adc8">
                                    <Run Text="Аутентичность: "/>
                                    <Run Text="{Binding SelectedFile.Authenticity}" FontWeight="Bold"
                                         Foreground="{Binding SelectedFile.Authenticity, Converter={StaticResource AuthToColor}}"/>
                                    <Run Text=" | Качество: "/>
                                    <Run Text="{Binding SelectedFile.QualityScore, StringFormat={}{0}/10}" FontWeight="Bold"
                                         Foreground="{Binding SelectedFile.QualityScore, Converter={StaticResource ScoreToColor}}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Metrics table -->
                        <ItemsControl ItemsSource="{Binding SelectedFile.MetricItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl>
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Style.Triggers>
                                                    <!-- Header row -->
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               Foreground="#89b4fa"
                                                                               FontSize="12" FontWeight="Bold"
                                                                               Margin="0,10,0,4"
                                                                               TextDecorations="Underline"/>
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <!-- Metric row -->
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="False">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <Border Background="#1e1e2e" CornerRadius="4"
                                                                            Padding="8,5" Margin="0,1">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <StackPanel Grid.Column="0">
                                                                                <TextBlock Text="{Binding Name}"
                                                                                           FontSize="10.5"
                                                                                           Foreground="#bac2de"
                                                                                           ToolTip="{Binding Description}"/>
                                                                                <TextBlock Text="{Binding Typical}"
                                                                                           FontSize="9"
                                                                                           Foreground="#585b70"
                                                                                           FontStyle="Italic"
                                                                                           Margin="0,2,0,0"
                                                                                           ToolTip="{Binding Description}"/>
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                                        VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding Value}"
                                                                                           FontSize="10.5"
                                                                                           FontFamily="Consolas"
                                                                                           Foreground="#cdd6f4"
                                                                                           FontWeight="SemiBold"
                                                                                           Margin="0,0,10,0"/>
                                                                                <Border CornerRadius="3" Padding="6,2"
                                                                                        Background="{Binding StatusColor}">
                                                                                    <TextBlock Text="{Binding Status}"
                                                                                               FontSize="9.5"
                                                                                               Foreground="#1e1e2e"
                                                                                               FontWeight="SemiBold"/>
                                                                                </Border>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Summary bar -->
        <Border Grid.Row="2" CornerRadius="8" Background="#313244" Padding="12,8" Margin="0,6,0,0">
            <TextBlock Text="{Binding SummaryText}" Foreground="#a6adc8" FontSize="13"/>
        </Border>
    </Grid>
</Window>
